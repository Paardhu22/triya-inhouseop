# =============================================================================
# Triya Manager - environment template. Copy to .env and fill in real values.
#   cp .env.example .env
# =============================================================================

# --- Database ---
# Local dev with docker-compose:
DATABASE_URL="postgresql://triya:triya_dev_password@localhost:5432/triya_manager?schema=public"

# --- Auth.js v5 ---
# Required. Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-strong-random-secret"
AUTH_TRUST_HOST="true"

# --- File storage ---
STORAGE_DRIVER="local"
STORAGE_LOCAL_DIR="./storage/uploads"
STORAGE_MAX_FILE_MB="10"

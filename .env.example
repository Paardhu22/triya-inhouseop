# =============================================================================
# Triya Manager - environment template. Copy to .env and fill in real values.
#   cp .env.example .env
# =============================================================================

# --- Database ---
# Local dev with docker-compose:
DATABASE_URL="postgresql://triya:triya_dev_password@localhost:5432/triya_manager?schema=public"

# --- Auth.js v5 ---
# Required. Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-strong-random-secret"
AUTH_TRUST_HOST="true"

# --- File storage ---
STORAGE_DRIVER="local"
STORAGE_LOCAL_DIR="./storage/uploads"
STORAGE_MAX_FILE_MB="10"

# --- Public base URL (used to build absolute media URLs for Twilio) ---
# Twilio fetches the invoice PDF from this URL, so it MUST be publicly reachable.
# localhost will NOT work (Twilio runs in the cloud) and is rejected with a clear
# error. In development, expose the dev server with a tunnel:
#   1) run the app:        npm run dev
#   2) start a tunnel:     ngrok http 3000
#   3) copy the https URL ngrok prints (e.g. https://ab12cd34.ngrok-free.app)
#   4) set it below and RESTART the server.
APP_PUBLIC_URL="http://localhost:3000"

# --- Twilio (WhatsApp invoice delivery). Server-only — never exposed to client. ---
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
# WhatsApp-enabled sender in E.164, e.g. the Twilio sandbox number.
TWILIO_WHATSAPP_NUMBER="+14155238886"
